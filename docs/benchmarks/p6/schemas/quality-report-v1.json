{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "P6 Protected Quality Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "implementation_commit",
    "production_tree",
    "full_suite",
    "profiles"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "implementation_commit": {
      "$ref": "#/$defs/git"
    },
    "production_tree": {
      "$ref": "#/$defs/git"
    },
    "full_suite": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "skipped",
        "xfail",
        "errors",
        "junit_sha256",
        "skip_node_ids"
      ],
      "properties": {
        "passed": {
          "const": 2625
        },
        "skipped": {
          "const": 9
        },
        "xfail": {
          "const": 0
        },
        "errors": {
          "const": 0
        },
        "junit_sha256": {
          "$ref": "#/$defs/sha"
        },
        "skip_node_ids": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "p5_language_graphs",
        "p4_exploration",
        "p2_context_pack",
        "ci",
        "pinned_real"
      ],
      "properties": {
        "p5_language_graphs": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "selected",
            "trace_coverage"
          ],
          "properties": {
            "passed": {
              "const": 12
            },
            "selected": {
              "const": 12
            },
            "trace_coverage": {
              "const": 1
            }
          }
        },
        "p4_exploration": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "selected",
            "trace_coverage"
          ],
          "properties": {
            "passed": {
              "const": 4
            },
            "selected": {
              "const": 4
            },
            "trace_coverage": {
              "const": 1
            }
          }
        },
        "p2_context_pack": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "selected",
            "trace_coverage"
          ],
          "properties": {
            "passed": {
              "const": 5
            },
            "selected": {
              "const": 5
            },
            "trace_coverage": {
              "const": 1
            }
          }
        },
        "ci": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "selected",
            "trace_coverage"
          ],
          "properties": {
            "passed": {
              "const": 8
            },
            "selected": {
              "const": 8
            },
            "trace_coverage": {
              "const": 1
            }
          }
        },
        "pinned_real": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "passed",
            "selected",
            "byte_identical"
          ],
          "properties": {
            "passed": {
              "const": 2
            },
            "selected": {
              "const": 2
            },
            "byte_identical": {
              "const": true
            }
          }
        }
      }
    }
  },
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    }
  }
}
