{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-search-tool.invalid/schemas/p6/matrix-report-v1.json",
  "title": "P6 Functional Matrix Aggregate v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "report_kind",
    "implementation_commit",
    "production_tree",
    "workflow_sha256",
    "dependency_lock_sha256",
    "run",
    "cells",
    "conclusion"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "report_kind": {"const": "matrix"},
    "implementation_commit": {"$ref": "#/$defs/git"},
    "production_tree": {"$ref": "#/$defs/git"},
    "workflow_sha256": {"$ref": "#/$defs/sha"},
    "dependency_lock_sha256": {"$ref": "#/$defs/sha"},
    "run": {"$ref": "#/$defs/run"},
    "cells": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/cell"}
    },
    "conclusion": {"const": "success"}
  },
  "$defs": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "git": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "passed",
        "failed",
        "errors",
        "skipped",
        "xfail",
        "skip_node_ids"
      ],
      "properties": {
        "passed": {"type": "integer", "minimum": 0},
        "failed": {"const": 0},
        "errors": {"const": 0},
        "skipped": {"type": "integer", "minimum": 0},
        "xfail": {"const": 0},
        "skip_node_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "run_id", "run_attempt"],
      "properties": {
        "evidence_id": {
          "type": "string",
          "pattern": "^p6-acceptance-[A-Za-z0-9._-]+$"
        },
        "run_id": {"type": "string", "pattern": "^[0-9]+$"},
        "run_attempt": {"type": "integer", "minimum": 1}
      }
    },
    "cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "architecture",
        "python_version",
        "tests",
        "junit_sha256"
      ],
      "properties": {
        "os": {
          "enum": ["ubuntu-latest", "macos-latest", "windows-latest"]
        },
        "architecture": {"type": "string", "minLength": 1},
        "python_version": {"enum": ["3.11", "3.12", "3.13", "3.14"]},
        "tests": {"$ref": "#/$defs/tests"},
        "junit_sha256": {"$ref": "#/$defs/sha"}
      }
    }
  }
}
